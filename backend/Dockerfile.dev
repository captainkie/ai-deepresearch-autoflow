# syntax=docker/dockerfile:1
# Dev image for the FastAPI backend — hot reload via `uvicorn --reload`.
# docker-compose bind-mounts the source over /app; deps live in a named volume
# (/app/.venv) so the bind mount never shadows the installed environment.
FROM python:3.12-slim

# uv from its official image: fast, reproducible installs straight from uv.lock.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ENV UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/app/.venv \
    UV_COMPILE_BYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    # watchfiles polling — reliable reloads over a macOS bind mount.
    WATCHFILES_FORCE_POLLING=true

WORKDIR /app

# Install dependencies first so this layer is cached until the lockfile changes.
# --no-install-project: the app itself is installed at runtime from the bind mount.
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project

# Fallback copy for a standalone `docker run`; compose bind-mounts over this.
COPY . .

EXPOSE 8000
CMD ["uv", "run", "--frozen", "uvicorn", "app.main:create_app", "--factory", \
     "--host", "0.0.0.0", "--port", "8000", "--reload"]
