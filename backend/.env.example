# AI DeepResearch AutoFlow — backend environment
# Copy to `.env` and fill in as needed. Mock providers need NO keys, so the
# offline pipeline (tests, CLI `--llm mock --search mock --crawl mock`) runs
# with none of these set.

# --- App ---
APP_ENV=development                 # development | production

# --- HTTP API (M2) ---
AUTOFLOW_DB_PATH=./data/autoflow.db          # SQLite file (parent dir auto-created)
AUTOFLOW_CORS_ORIGINS=http://localhost:3000  # comma-separated browser origins
AUTOFLOW_DEFAULT_REQUIRE_PLAN_APPROVAL=true   # default HITL for new runs

# --- Secret vault (M3) ---
# KEK for the AES-256-GCM credential vault. Base64, 32 bytes. Generate one with
# `uv run autoflow gen-key`. REQUIRED when APP_ENV=production (fail-fast if missing);
# in development a missing key is generated ephemerally (won't survive a restart).
AUTOFLOW_MASTER_KEY=

# JWT signing secret (HS256) for access tokens. At least 32 characters. REQUIRED when
# APP_ENV=production; dev generates an ephemeral one (all sessions drop on restart).
AUTOFLOW_JWT_SECRET=

# --- Google OAuth (M3c, optional) ---
# When all three are set, "Continue with Google" is enabled. GOOGLE_REDIRECT_URI must match
# the URI registered in Google Cloud Console, e.g. http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Where the OAuth callback returns the browser after a successful login:
AUTOFLOW_FRONTEND_URL=http://localhost:3000

# --- LLM provider keys (resolved at call time; only needed for real providers) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Search provider keys (DuckDuckGo is keyless) ---
TAVILY_API_KEY=
SERPER_API_KEY=
EXA_API_KEY=

# --- Provider selectors (override RunConfig defaults) ---
AUTOFLOW_LLM_PROVIDER=mock          # mock | litellm
AUTOFLOW_LLM_MODEL=mock-1
AUTOFLOW_SEARCH_PROVIDER=mock       # mock | tavily | serper | exa | duckduckgo
AUTOFLOW_CRAWL_PROVIDER=mock        # mock | jina | trafilatura
AUTOFLOW_LANGUAGE=en                # en | th
AUTOFLOW_TEMPLATE=deep_research
AUTOFLOW_REQUIRE_PLAN_APPROVAL=false

# z.ai GLM (LiteLLM zai/ prefix, e.g. zai/glm-4.6)
ZAI_API_KEY=
# Moonshot Kimi (LiteLLM moonshot/ prefix, e.g. moonshot/kimi-k2-...)
MOONSHOT_API_KEY=
# MOONSHOT_API_BASE=https://api.moonshot.ai/v1
