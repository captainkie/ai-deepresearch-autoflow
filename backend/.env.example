# AI DeepResearch AutoFlow — backend environment
# Copy to `.env` and fill in as needed. Mock providers need NO keys, so the
# offline pipeline (tests, CLI `--llm mock --search mock --crawl mock`) runs
# with none of these set.

# --- App ---
APP_ENV=development                 # development | production

# --- HTTP API (M2) ---
AUTOFLOW_DB_PATH=./data/autoflow.db          # SQLite file (parent dir auto-created)
AUTOFLOW_CORS_ORIGINS=http://localhost:3000  # comma-separated browser origins
AUTOFLOW_DEFAULT_REQUIRE_PLAN_APPROVAL=true   # default HITL for new runs

# --- Secret vault (later milestone) ---
# AUTOFLOW_MASTER_KEY: base64-encoded 32 bytes; required when APP_ENV=production.
AUTOFLOW_MASTER_KEY=

# --- LLM provider keys (resolved at call time; only needed for real providers) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Search provider keys (DuckDuckGo is keyless) ---
TAVILY_API_KEY=
SERPER_API_KEY=
EXA_API_KEY=

# --- Provider selectors (override RunConfig defaults) ---
AUTOFLOW_LLM_PROVIDER=mock          # mock | litellm
AUTOFLOW_LLM_MODEL=mock-1
AUTOFLOW_SEARCH_PROVIDER=mock       # mock | tavily | serper | exa | duckduckgo
AUTOFLOW_CRAWL_PROVIDER=mock        # mock | jina | trafilatura
AUTOFLOW_LANGUAGE=en                # en | th
AUTOFLOW_TEMPLATE=deep_research
AUTOFLOW_REQUIRE_PLAN_APPROVAL=false
